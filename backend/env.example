# 复制为 backend/.env 后填写真实密钥（勿把密钥提交到 git）。
# 也可把 .env 放在 monorepo 根目录 rag-project/.env（pnpm 从 backend 目录启动时会自动读 ../.env）。
# 详见 src/load-env.ts。

PORT_BACKEND=3001
MILVUS_ADDRESS=localhost:19530
COLLECTION_NAME=ebook_collection
VECTOR_DIM=1024
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDINGS_MODEL_NAME=text-embedding-v3
# 归纳回答用的对话模型（与 DashScope/OpenAI 兼容网关一致）
MODEL_NAME=qwen-coder-turbo
